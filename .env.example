# Local development
NODE_ENV=development
PORT=3000

# Current server database fallback.
# Keep this empty while migrating to Supabase unless the existing MySQL flow is needed.
DATABASE_URL=
JWT_SECRET=replace-with-a-long-random-secret

# Supabase client configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase server-side configuration.
# Never expose the service role key to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional API key encryption secret for user-saved provider keys.
# Use a stable 32+ byte value in production.
API_KEY_ENCRYPTION_SECRET=replace-with-a-stable-secret

# Provider keys used by server or Supabase Edge Functions.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
YOUTUBE_API_KEY=

# Legacy Manus OAuth values. Leave empty after Supabase Auth migration.
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Legacy Manus Forge values. Leave empty after storage/AI/map migration.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
